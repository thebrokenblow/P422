<Window
    x:Class="Lesson4.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lesson4"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock Text="{Binding Result}" />
        <StackPanel Orientation="Horizontal">
            <Label Content="a: " />
            <TextBox Width="300" Text="{Binding A, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Label Content="b: " />
            <TextBox Width="300" Text="{Binding B, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        <Button Command="{Binding AddCommand}" Content="Посчитать" />
    </StackPanel>
</Window>
