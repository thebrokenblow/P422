<Window
    x:Class="Lesson2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lesson2"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <StackPanel>
        <StackPanel>
            <CheckBox
                Checked="CheckBox_Checked"
                Content="Есть ли отчество"
                Unchecked="CheckBox_Checked" />
            <StackPanel Orientation="Horizontal">
                <Label Content="Отчество: " />
                <TextBox Name="PatronymicTextFiled" Width="350" />
            </StackPanel>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Автором работы «История государства Российского» является" />
            <RadioButton
                Checked="RadioButton_FirstQuestion_Checked"
                Content="Н.М. Карамзин"
                GroupName="FirstQuestion" />
            <RadioButton
                Checked="RadioButton_FirstQuestion_Checked"
                Content="В.Н. Татищев"
                GroupName="FirstQuestion" />
            <RadioButton
                Checked="RadioButton_FirstQuestion_Checked"
                Content="С.Ф. Платонов"
                GroupName="FirstQuestion" />
            <RadioButton
                Checked="RadioButton_FirstQuestion_Checked"
                Content="С.М. Соловьев"
                GroupName="FirstQuestion" />
        </StackPanel>

        <StackPanel Margin="0,30,0,0">
            <TextBlock Text="Период царствования Николая I характеризуется" />
            <RadioButton
                Checked="RadioButton_SecondQuestion_Checked"
                Content="Усилением местного самоуправления"
                GroupName="SecondQuestion" />
            <RadioButton
                Checked="RadioButton_SecondQuestion_Checked"
                Content="Появлением «военных поселений»"
                GroupName="SecondQuestion" />
            <RadioButton
                Checked="RadioButton_SecondQuestion_Checked"
                Content="Либеральными реформами в области печати и образования"
                GroupName="SecondQuestion" />
            <RadioButton
                Checked="RadioButton_SecondQuestion_Checked"
                Content="Началом промышленного переворота"
                GroupName="SecondQuestion" />
        </StackPanel>
    </StackPanel>
</Window>
