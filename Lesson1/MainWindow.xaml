<Window
    x:Class="Lesson1.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lesson1"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <StackPanel
        Width="400"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Width="120" Content="Введите имя: " />
                <TextBox Name="FirstNameTextBox" Width="280" />
            </StackPanel>
            <TextBlock
                Name="ErrorResultFirstName"
                HorizontalAlignment="Center"
                Foreground="Red" />
        </StackPanel>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Width="120" Content="Введите фамилию: " />
                <TextBox Name="LastNameTextBox" Width="280" />
            </StackPanel>
            <TextBlock
                Name="ErrorResultLastName"
                HorizontalAlignment="Center"
                Foreground="Red" />
        </StackPanel>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label Width="120" Content="Введите отчество: " />
                <TextBox Name="PatronymicTextBox" Width="280" />
            </StackPanel>
            <TextBlock
                Name="ErrorResultPatronymic"
                HorizontalAlignment="Center"
                Foreground="Red" />
        </StackPanel>
        <Button
            Width="400"
            Click="Button_Click_SaveData"
            Content="Сохранить" />
    </StackPanel>
</Window>
