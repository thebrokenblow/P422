<Window
    x:Class="Lesson5.Second.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Lesson5.Second"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Grid>
        <DataGrid Name="listProducts" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Binding="{Binding Id}"
                    Header="ID" />

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Name}"
                    Header="Название товара" />

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Category}"
                    Header="Категория" />

                <DataGridTextColumn
                    Width="Auto"
                    Binding="{Binding Price}"
                    Header="Цена (руб)" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
